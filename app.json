{
  "expo": {
    "name": "Moka",
    "slug": "moka-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "moka",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.africorex.moka"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D5016",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.africorex.moka"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#2D5016"
        }
      ],
      "expo-sharing",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65d9124b-fb39-4352-b56d-7007f75b131a"
      }
    }
  }
}
